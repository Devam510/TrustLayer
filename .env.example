# TrustLayer Environment Variables
# Copy this file to .env and fill in your values.

# ─── Database ────────────────────────────────────────────
DATABASE_URL=postgresql://trustlayer:trustlayer@localhost:5432/trustlayer
DATABASE_URL_UNPOOLED=postgresql://trustlayer:trustlayer@localhost:5432/trustlayer

# ─── Redis ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth (Better-Auth / RS256) ──────────────────────────
BETTER_AUTH_SECRET=your-32-char-secret-here
BETTER_AUTH_URL=http://localhost:3000

# RS256 key pair (generate via: openssl genrsa -out private.pem 2048)
JWT_PRIVATE_KEY_PATH=./certs/private.pem
JWT_PUBLIC_KEY_PATH=./certs/public.pem

# ─── Stripe ──────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_AGENCY=price_...

# ─── Plaid ───────────────────────────────────────────────
PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-secret
PLAID_ENV=sandbox

# ─── Resend ──────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@trustlayer.dev
LOOPS_API_KEY=...

# ─── Sentry ──────────────────────────────────────────────
SENTRY_DSN_API=https://...@sentry.io/...
SENTRY_DSN_WEB=https://...@sentry.io/...
SENTRY_AUTH_TOKEN=...
SENTRY_ORG=trustlayer
SENTRY_PROJECT_API=trustlayer-api
SENTRY_PROJECT_WEB=trustlayer-web

# ─── PostHog ─────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ─── Crypto / Key Rotation ───────────────────────────────
ENCRYPTION_KEY_V1=<64-hex-chars-AES-256>
CURRENT_ENCRYPTION_KEY_VERSION=1

# ─── Admin ───────────────────────────────────────────────
ADMIN_ALLOWED_IPS=127.0.0.1,::1

# ─── App ─────────────────────────────────────────────────
API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000
NODE_ENV=development

# ─── Cloudflare R2 (Phase 5) ─────────────────────────────
CLOUDFLARE_R2_ACCOUNT_ID=...
CLOUDFLARE_R2_ACCESS_KEY_ID=...
CLOUDFLARE_R2_SECRET_ACCESS_KEY=...
CLOUDFLARE_R2_BUCKET=trustlayer-exports
